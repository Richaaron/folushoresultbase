{
  "version": 2,
  "buildCommand": "cd frontend-react && npm run build",
  "installCommand": "npm install && cd frontend-react && npm install && cd ../backend && npm install",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "zeroConfig": true,
        "includeFiles": "backend/**"
      }
    },
    {
      "src": "frontend-react/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend-react/dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-react/dist/$1"
    },
    {
      "src": "/[^.]+$",
      "dest": "frontend-react/dist/index.html"
    }
  ],
  "env": {
    "DATABASE_URL": {
      "description": "Supabase PostgreSQL connection string"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token signing"
    },
    "FRONTEND_URL": {
      "description": "Frontend URL for CORS"
    }
  }
}
